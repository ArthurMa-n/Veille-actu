<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ma Veille Actu</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #ffffff;
      --bg-secondary: #f7f7f5;
      --bg-tertiary: #f0efe9;
      --text: #1a1a18;
      --text-secondary: #5f5e5a;
      --text-tertiary: #888780;
      --border: rgba(0,0,0,0.12);
      --border-strong: rgba(0,0,0,0.22);
      --radius-md: 8px;
      --radius-lg: 12px;
      --tag-health-bg: #E1F5EE; --tag-health-fg: #0F6E56;
      --tag-fr-bg: #E6F1FB; --tag-fr-fg: #185FA5;
      --tag-world-bg: #FAEEDA; --tag-world-fg: #854F0B;
      --dot-health: #1D9E75; --dot-fr: #185FA5; --dot-world: #BA7517;
      --error-bg: #FCEBEB; --error-fg: #A32D2D; --error-border: rgba(163,45,45,0.3);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1c1c1a;
        --bg-secondary: #252523;
        --bg-tertiary: #2c2c2a;
        --text: #f0efe9;
        --text-secondary: #b4b2a9;
        --text-tertiary: #888780;
        --border: rgba(255,255,255,0.1);
        --border-strong: rgba(255,255,255,0.2);
        --tag-health-bg: #085041; --tag-health-fg: #9FE1CB;
        --tag-fr-bg: #0C447C; --tag-fr-fg: #B5D4F4;
        --tag-world-bg: #633806; --tag-world-fg: #FAC775;
        --error-bg: #501313; --error-fg: #F7C1C1; --error-border: rgba(247,193,193,0.3);
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-tertiary);
      color: var(--text);
      min-height: 100vh;
      padding: 0;
    }

    .page-wrapper {
      max-width: 760px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }

    /* API KEY BANNER */
    .api-banner {
      background: var(--bg);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 14px 16px;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .api-banner label {
      font-size: 12px;
      font-weight: 500;
      color: var(--text-secondary);
      white-space: nowrap;
    }
    .api-input {
      flex: 1;
      min-width: 200px;
      padding: 6px 10px;
      border: 0.5px solid var(--border);
      border-radius: var(--radius-md);
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      background: var(--bg-secondary);
      color: var(--text);
      outline: none;
      letter-spacing: 0.5px;
    }
    .api-input:focus { border-color: var(--border-strong); }
    .api-save-btn {
      padding: 6px 14px;
      border: 0.5px solid var(--border-strong);
      border-radius: var(--radius-md);
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--text);
      cursor: pointer;
      white-space: nowrap;
    }
    .api-save-btn:hover { background: var(--bg-secondary); }
    .api-status {
      font-size: 11px;
      color: var(--tag-health-fg);
      font-weight: 500;
    }
    .api-status.missing { color: var(--error-fg); }

    /* HEADER */
    .header {
      padding: 0 0 1.25rem;
      border-bottom: 0.5px solid var(--border);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .header-title {
      font-family: 'DM Serif Display', serif;
      font-size: 28px;
      font-weight: 400;
      letter-spacing: -0.5px;
      color: var(--text);
    }
    .header-date { font-size: 13px; color: var(--text-tertiary); font-weight: 300; }

    /* TABS */
    .tabs {
      display: flex;
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 1.5rem;
      background: var(--bg);
    }
    .tab-btn {
      flex: 1; padding: 11px 8px;
      border: none; background: transparent;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 400;
      color: var(--text-secondary); cursor: pointer;
      transition: all 0.15s;
      border-right: 0.5px solid var(--border);
      display: flex; align-items: center; justify-content: center; gap: 7px;
    }
    .tab-btn:last-child { border-right: none; }
    .tab-btn .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .tab-btn.active { background: var(--bg-secondary); color: var(--text); font-weight: 500; }
    .tab-btn:hover:not(.active) { background: var(--bg-secondary); }

    /* SECTION */
    .section { display: none; }
    .section.active { display: block; }

    .section-legend {
      font-size: 11px; color: var(--text-tertiary); line-height: 1.6;
      padding: 8px 12px; margin-bottom: 1rem;
      border: 0.5px solid var(--border); border-radius: var(--radius-md);
      background: var(--bg-secondary);
    }
    .section-legend strong { color: var(--text-secondary); font-weight: 500; }

    .search-bar { display: flex; gap: 8px; margin-bottom: 1.25rem; }
    .search-input {
      flex: 1; padding: 9px 12px;
      border: 0.5px solid var(--border); border-radius: var(--radius-md);
      font-family: 'DM Sans', sans-serif; font-size: 13px;
      background: var(--bg); color: var(--text); outline: none;
    }
    .search-input:focus { border-color: var(--border-strong); }
    .btn-search {
      padding: 9px 18px;
      border: 0.5px solid var(--border-strong); border-radius: var(--radius-md);
      background: var(--bg); font-family: 'DM Sans', sans-serif;
      font-size: 13px; font-weight: 500; color: var(--text);
      cursor: pointer; white-space: nowrap;
    }
    .btn-search:hover { background: var(--bg-secondary); }
    .btn-search:active { transform: scale(0.98); }

    .news-list { display: flex; flex-direction: column; gap: 10px; min-height: 160px; }

    .news-card {
      background: var(--bg);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg); padding: 14px 16px;
      transition: border-color 0.12s;
    }
    .news-card:hover { border-color: var(--border-strong); }
    .news-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 7px; }
    .news-title { font-size: 14px; font-weight: 500; line-height: 1.5; flex: 1; }
    .badge-col { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; flex-shrink: 0; }

    .news-tag { font-size: 11px; font-weight: 500; padding: 2px 9px; border-radius: 20px; white-space: nowrap; }
    .news-format {
      font-size: 10px; font-weight: 500; padding: 2px 7px; border-radius: 20px;
      text-transform: uppercase; letter-spacing: 0.3px; white-space: nowrap;
      background: var(--bg-secondary); color: var(--text-tertiary);
    }

    .tag-health { background: var(--tag-health-bg); color: var(--tag-health-fg); }
    .tag-fr { background: var(--tag-fr-bg); color: var(--tag-fr-fg); }
    .tag-world { background: var(--tag-world-bg); color: var(--tag-world-fg); }

    .news-summary { font-size: 13px; font-weight: 300; color: var(--text-secondary); line-height: 1.65; margin-bottom: 8px; }
    .news-meta { font-size: 11px; color: var(--text-tertiary); display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .source-badge {
      font-size: 10px; font-weight: 500; padding: 1px 7px; border-radius: 4px;
      background: var(--bg-tertiary); color: var(--text-secondary);
      border: 0.5px solid var(--border);
    }
    .author { font-style: italic; color: var(--text-secondary); }

    .loading-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 3rem 1rem; gap: 12px; color: var(--text-secondary); font-size: 13px;
    }
    .spinner {
      width: 20px; height: 20px;
      border: 1.5px solid var(--border); border-top-color: var(--text-secondary);
      border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    .empty-state {
      display: flex; align-items: center; justify-content: center;
      padding: 3rem 1rem; color: var(--text-tertiary); font-size: 13px; text-align: center;
    }
    .error-state {
      background: var(--error-bg); border: 0.5px solid var(--error-border);
      border-radius: var(--radius-md); padding: 12px 16px;
      font-size: 13px; color: var(--error-fg); text-align: center; line-height: 1.5;
    }

    .refresh-row {
      display: flex; align-items: center; justify-content: space-between;
      margin-top: 1rem; padding-top: 1rem; border-top: 0.5px solid var(--border);
    }
    .last-updated { font-size: 11px; color: var(--text-tertiary); }
    .btn-refresh {
      font-size: 12px; font-weight: 500; color: var(--text-secondary);
      background: none; border: none; cursor: pointer; padding: 4px 8px;
      border-radius: var(--radius-md); font-family: 'DM Sans', sans-serif;
    }
    .btn-refresh:hover { background: var(--bg-secondary); }

    .footer {
      margin-top: 3rem; padding-top: 1.5rem; border-top: 0.5px solid var(--border);
      font-size: 11px; color: var(--text-tertiary); text-align: center;
    }
  </style>
</head>
<body>
<div class="page-wrapper">

  <!-- API KEY BANNER -->
  <div class="api-banner">
    <label>🔑 Clé API Anthropic</label>
    <input class="api-input" id="api-key-input" type="password" placeholder="sk-ant-..." />
    <button class="api-save-btn" onclick="saveApiKey()">Enregistrer</button>
    <span class="api-status missing" id="api-status">Non configurée</span>
  </div>

  <!-- HEADER -->
  <div class="header">
    <span class="header-title">Ma Veille Actu</span>
    <span class="header-date" id="current-date"></span>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" data-tab="health" onclick="switchTab('health')">
      <span class="dot" style="background:var(--dot-health)"></span> E-santé
    </button>
    <button class="tab-btn" data-tab="finance-fr" onclick="switchTab('finance-fr')">
      <span class="dot" style="background:var(--dot-fr)"></span> Finance FR
    </button>
    <button class="tab-btn" data-tab="finance-world" onclick="switchTab('finance-world')">
      <span class="dot" style="background:var(--dot-world)"></span> Finance Monde
    </button>
  </div>

  <!-- E-SANTÉ -->
  <div id="section-health" class="section active">
    <div class="section-legend">
      <strong>Format :</strong> 1 actualité réglementaire/politique · 1 entreprise ou solution · 1 déploiement terrain (éditeur × hôpital)
    </div>
    <div class="search-bar">
      <input class="search-input" id="q-health" type="text" value="e-santé numérique santé France actualités 2026" />
      <button class="btn-search" onclick="fetchNews('health')">Chercher ↗</button>
    </div>
    <div class="news-list" id="news-health">
      <div class="empty-state">🏥 Configure ta clé API puis clique sur "Chercher"</div>
    </div>
    <div class="refresh-row">
      <span class="last-updated" id="lu-health"></span>
      <button class="btn-refresh" onclick="fetchNews('health')">Actualiser</button>
    </div>
  </div>

  <!-- FINANCE FR -->
  <div id="section-finance-fr" class="section">
    <div class="section-legend">
      <strong>Sources :</strong> Les Échos, Le Figaro Économie, La Tribune, BFM Business &nbsp;·&nbsp;
      <strong>Format :</strong> 1 macro · 1 industrie/entreprise/transaction · 1 op-ed
    </div>
    <div class="search-bar">
      <input class="search-input" id="q-finance-fr" type="text" value="finance économie France actualités mars 2026" />
      <button class="btn-search" onclick="fetchNews('finance-fr')">Chercher ↗</button>
    </div>
    <div class="news-list" id="news-finance-fr">
      <div class="empty-state">🇫🇷 Configure ta clé API puis clique sur "Chercher"</div>
    </div>
    <div class="refresh-row">
      <span class="last-updated" id="lu-finance-fr"></span>
      <button class="btn-refresh" onclick="fetchNews('finance-fr')">Actualiser</button>
    </div>
  </div>

  <!-- FINANCE MONDE -->
  <div id="section-finance-world" class="section">
    <div class="section-legend">
      <strong>Sources :</strong> Wall Street Journal, Financial Times, Bloomberg, The Economist &nbsp;·&nbsp;
      <strong>Format :</strong> 1 macro · 1 industrie/entreprise/transaction · 1 op-ed
    </div>
    <div class="search-bar">
      <input class="search-input" id="q-finance-world" type="text" value="global finance markets economy news March 2026" />
      <button class="btn-search" onclick="fetchNews('finance-world')">Chercher ↗</button>
    </div>
    <div class="news-list" id="news-finance-world">
      <div class="empty-state">🌍 Configure ta clé API puis clique sur "Chercher"</div>
    </div>
    <div class="refresh-row">
      <span class="last-updated" id="lu-finance-world"></span>
      <button class="btn-refresh" onclick="fetchNews('finance-world')">Actualiser</button>
    </div>
  </div>

  <div class="footer">Dashboard de veille personnelle · Propulsé par Claude + Web Search</div>
</div>

<script>
const PROMPTS = {
  health: `Tu es un expert en e-santé et transformation numérique hospitalière en France. Effectue une recherche web sur le sujet fourni.

Tu dois retourner EXACTEMENT 3 articles structurés selon ces 3 formats obligatoires :
1. "Réglementaire" : une actualité de politique publique, réglementation ou décision institutionnelle (ANS, Ministère Santé, Ségur, HAS, CNIL...)
2. "Solution" : présentation d'une entreprise, startup ou solution numérique en santé (fonctionnement, marché, différenciation)
3. "Déploiement" : un projet concret entre un éditeur/solution et un établissement de santé (hôpital, EHPAD, clinique), avec des détails terrain

Retourne UNIQUEMENT un JSON valide, sans texte avant/après ni balises markdown :
{"articles":[{"title":"...","summary":"Résumé de 2-3 phrases précises.","tag":"Réglementaire","format_label":"Réglementaire","source":"Nom source","date":"Ex: Mars 2026"},{"title":"...","summary":"...","tag":"Solution","format_label":"Solution","source":"...","date":"..."},{"title":"...","summary":"...","tag":"Déploiement","format_label":"Déploiement","source":"...","date":"..."}]}`,

  'finance-fr': `Tu es un journaliste économique senior spécialisé en finance française. Effectue une recherche web en ciblant prioritairement : Les Échos, Le Figaro Économie, La Tribune, BFM Business.

Tu dois retourner EXACTEMENT 3 articles :
1. "Macro" : sujet macroéconomique (PIB, inflation, BCE, taux, emploi, budget...)
2. "Micro" : industrie, entreprise CAC/SBF, ou transaction (M&A, IPO, résultats, levée de fonds...)
3. "Op-Ed" : tribune ou éditorial d'opinion d'un économiste ou expert (indiquer l'auteur)

Retourne UNIQUEMENT un JSON valide, sans texte avant/après ni balises markdown :
{"articles":[{"title":"...","summary":"...","tag":"Macro","format_label":"Macro","source":"Les Échos","date":"...","author":""},{"title":"...","summary":"...","tag":"Micro","format_label":"Micro","source":"...","date":"...","author":""},{"title":"...","summary":"...","tag":"Op-Ed","format_label":"Op-Ed","source":"...","date":"...","author":"Prénom Nom, titre"}]}`,

  'finance-world': `Tu es un journaliste financier senior spécialisé en marchés mondiaux. Effectue une recherche web en ciblant prioritairement : Wall Street Journal, Financial Times, Bloomberg, The Economist, Reuters.

Tu dois retourner EXACTEMENT 3 articles :
1. "Macro" : sujet macroéconomique mondial (Fed, inflation US, croissance, géopolitique économique...)
2. "Micro" : industrie, entreprise ou transaction internationale (résultats, M&A, IPO, disruption sectorielle...)
3. "Op-Ed" : tribune ou analyse éditoriale (WSJ Opinion, FT Lex, The Economist leader...) avec auteur

Retourne UNIQUEMENT un JSON valide, sans texte avant/après ni balises markdown :
{"articles":[{"title":"...","summary":"...","tag":"Macro","format_label":"Macro","source":"Wall Street Journal","date":"...","author":""},{"title":"...","summary":"...","tag":"Micro","format_label":"Micro","source":"...","date":"...","author":""},{"title":"...","summary":"...","tag":"Op-Ed","format_label":"Op-Ed","source":"...","date":"...","author":"Prénom Nom, titre"}]}`
};

const TAG_CLASSES = { health: 'tag-health', 'finance-fr': 'tag-fr', 'finance-world': 'tag-world' };
let API_KEY = localStorage.getItem('anthropic_api_key') || '';

function init() {
  const d = new Date();
  document.getElementById('current-date').textContent = d.toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  if (API_KEY) {
    document.getElementById('api-key-input').value = API_KEY;
    document.getElementById('api-status').textContent = '✓ Configurée';
    document.getElementById('api-status').classList.remove('missing');
  }
}

function saveApiKey() {
  const val = document.getElementById('api-key-input').value.trim();
  if (!val.startsWith('sk-ant-')) {
    alert('La clé doit commencer par "sk-ant-"');
    return;
  }
  API_KEY = val;
  localStorage.setItem('anthropic_api_key', val);
  document.getElementById('api-status').textContent = '✓ Configurée';
  document.getElementById('api-status').classList.remove('missing');
}

function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelector('[data-tab="' + tab + '"]').classList.add('active');
  document.getElementById('section-' + tab).classList.add('active');
}

function showLoading(id) {
  document.getElementById(id).innerHTML = '<div class="loading-state"><div class="spinner"></div><span>Recherche sur les sources sélectionnées...</span></div>';
}

function showError(id, msg) {
  document.getElementById(id).innerHTML = '<div class="error-state">' + msg + '</div>';
}

function renderArticles(containerId, articles, tagClass) {
  if (!articles || !articles.length) {
    document.getElementById(containerId).innerHTML = '<div class="empty-state">Aucun résultat trouvé.</div>';
    return;
  }
  document.getElementById(containerId).innerHTML = articles.map(function(a) {
    var authorHtml = a.author ? '<span class="author">' + a.author + '</span>' : '';
    return '<div class="news-card">'
      + '<div class="news-card-top">'
      + '<span class="news-title">' + a.title + '</span>'
      + '<div class="badge-col">'
      + '<span class="news-tag ' + tagClass + '">' + (a.tag || '') + '</span>'
      + (a.format_label ? '<span class="news-format">' + a.format_label + '</span>' : '')
      + '</div></div>'
      + '<p class="news-summary">' + a.summary + '</p>'
      + '<div class="news-meta">'
      + (a.source ? '<span class="source-badge">' + a.source + '</span>' : '')
      + authorHtml
      + (a.date || '')
      + '</div></div>';
  }).join('');
}

async function fetchNews(tabId) {
  if (!API_KEY) {
    alert('Configure d\'abord ta clé API Anthropic en haut de la page.');
    return;
  }
  var query = document.getElementById('q-' + tabId).value.trim();
  if (!query) return;
  var containerId = 'news-' + tabId;
  showLoading(containerId);
  try {
    var resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': API_KEY,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1500,
        system: PROMPTS[tabId],
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{ role: 'user', content: query }]
      })
    });
    if (!resp.ok) {
      var err = await resp.json().catch(function() { return {}; });
      throw new Error((err.error && err.error.message) || 'Erreur API ' + resp.status);
    }
    var data = await resp.json();
    var textBlock = data.content.find(function(b) { return b.type === 'text'; });
    if (!textBlock) throw new Error('Pas de réponse texte');
    var raw = textBlock.text.replace(/```json|```/g, '').trim();
    var parsed = JSON.parse(raw);
    renderArticles(containerId, parsed.articles, TAG_CLASSES[tabId]);
    var now = new Date();
    document.getElementById('lu-' + tabId).textContent = 'Mis à jour à ' + now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
  } catch(err) {
    showError(containerId, 'Erreur : ' + err.message + '<br><small>Vérifie ta clé API et ta connexion.</small>');
  }
}

init();
</script>
</body>
</html>
